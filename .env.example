# ─── Business profile (identity — all optional, configurable, nothing presumed) ─
# Drives branding, AI prompts, outreach sign-off, digest, and map center.
# Leave a value blank to drop that claim (e.g. empty CITY → no location stated).
# NEXT_PUBLIC_BUSINESS_NAME="1COMMERCE Drone Ops"
# NEXT_PUBLIC_BUSINESS_TAGLINE="Drone Ops"
# NEXT_PUBLIC_BUSINESS_SIGNER=""          # outreach signer; blank → "[Your name]"
# NEXT_PUBLIC_BUSINESS_CITY="Canby, Oregon"
# NEXT_PUBLIC_BUSINESS_REGION="Oregon's Willamette Valley"
# NEXT_PUBLIC_BUSINESS_EQUIPMENT="DJI Agras T50"
# NEXT_PUBLIC_BUSINESS_RADIUS_MI=60
# NEXT_PUBLIC_BUSINESS_LAT=45.2662
# NEXT_PUBLIC_BUSINESS_LON=-122.6926

# ─── Supabase (client, public — copy from Supabase Settings → API) ──────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Lead Intelligence Engine (server-side only — set in Vercel, never commit) ─
# Enables AI web research + reasoning. Without it, the engine still runs the
# algorithmic prioritization + completeness pass. Used for the ENRICH stage.
ANTHROPIC_API_KEY=sk-ant-...

# ─── Discover Leads (server-side only) ─────────────────────────────────────
# Discovery finds prospects in three stages and does NOT use Anthropic credits:
#   SEARCH  → Brave + Tavily web search find candidate businesses
#   INFER   → Groq (GROQ_API_KEY below) extracts structured lead stubs
#   ENRICH  → the Claude engine (ANTHROPIC_API_KEY) verifies them afterward
# At least one search provider is required; both are used together when set.
BRAVE_API_KEY=                       # https://api.search.brave.com (X-Subscription-Token)
TAVILY_API_KEY=tvly-...              # https://tavily.com
# DISCOVERY_MODEL=llama-3.3-70b-versatile   # Groq model for the infer stage
#
# Optional: run the SEARCH stage on a Cloudflare Worker instead (keys stay on
# Cloudflare + KV cache). See workers/discovery-search/README.md. When set, the
# app sends queries to the worker and BRAVE/TAVILY keys live there, not here.
# DISCOVERY_WORKER_URL=https://drone-discovery-search.<subdomain>.workers.dev
# DISCOVERY_WORKER_SECRET=<matches the worker's WORKER_SHARED_SECRET>

# Service-role key for server-side writes (preferred over the anon key).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Protects the cron/run endpoint. With ENRICHMENT_REQUIRE_SECRET=true, manual
# triggers must pass `Authorization: Bearer <CRON_SECRET>` (or ?secret=).
CRON_SECRET=change-me
ENRICHMENT_REQUIRE_SECRET=false

# Optional: contact-data booster (phone/email) from Apollo.io.
APOLLO_API_KEY=

# ─── Engine tuning (all optional, sensible defaults) ───────────────────────
# ENRICHMENT_MODEL=claude-sonnet-4-6   # default; set claude-opus-4-8 for max quality
# ENRICHMENT_EFFORT=medium          # low | medium | high
# ENRICHMENT_BATCH_SIZE=6           # leads per run
# ENRICHMENT_CONCURRENCY=3          # parallel research calls
# ENRICHMENT_STALE_DAYS=7           # re-research leads older than this

# ─── AI Ops Assistant (/assistant) — provider & model ──────────────────────
# Default: Claude (Sonnet 4.6). Override the Claude model with ASSISTANT_MODEL.
# ASSISTANT_MODEL=claude-sonnet-4-6
#
# Or run the assistant on Groq (fast + cheap, open models with tool calling):
# ASSISTANT_PROVIDER=groq
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# ─── Cheap inference for digest narration, outreach drafts & smart search ───
# These features auto-use whatever is set, preferring: AI_PROVIDER → Groq →
# OpenRouter → Anthropic. (Web-search research stays on Claude in the engine.)
# AI_PROVIDER=groq                  # optional explicit: groq | openrouter | anthropic
# GROQ_API_KEY=gsk_...              # (shared with the assistant above)
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Optional — for scraper notifications + the daily ops digest
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
